{
  "name": "simple-nodejs-mongodb-user-register-web-app",
  "version": "1.0.0",
  "description": "A simple user registration web app with Node.js, Express, MongoDB, and EJS.",
  "homepage": "https://github.com/coderooz/simple-nodejs-mongodb-user-register-web-app#readme",
  "main": "main.js",
  "scripts": {
  "start": "node main.js",
  "dev": "nodemon main.js",
  "test": "jest --runInBand --coverage --detectOpenHandles",
  "test:ci": "jest --runInBand --coverage --ci --detectOpenHandles --forceExit --reporters=default --reporters=jest-junit"
},
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "mongoose",
    "ejs",
    "crud",
    "user-management"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coderooz/simple-nodejs-mongodb-user-register-web-app.git"
  },
  "bugs": {
    "url": "https://github.com/coderooz/simple-nodejs-mongodb-user-register-web-app/issues"
  },
  "author": "Ranit Saha (Coderooz)",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "mongoose": "^8.5.3",
    "multer": "^1.4.5-lts.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  },
  "jest-junit": {
    "outputDirectory": ".",
    "outputName": "junit.xml"
  },
  "jest": {
  "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"],
  "testEnvironment": "node"
}
}
